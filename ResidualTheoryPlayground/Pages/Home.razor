@page "/"
@using MermaidJS.Blazor
@inject SystemModel Model

<PageTitle>Home</PageTitle>

<h1>Result of the residue analysis!</h1>

<div class="row">
    <div class="col">
        <h2>Original system</h2>
        <MermaidDiagram Definition="@Model.OriginalModel" />
    </div>
    <div class="col">        
        <h2>Planned stressors</h2>
        <h2>Unplanned stressors</h2>
    </div>
    <div class="col">        
        <h2>New system</h2>
        <MermaidDiagram Definition="@Model.NewModel" />
    </div>
</div>